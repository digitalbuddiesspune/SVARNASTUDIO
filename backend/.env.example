MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/svarnastudio

# Comma-separated frontend origins (optional — defaults include svarnastudio.in + localhost)
CORS_ORIGINS=https://www.svarnastudio.in,https://svarnastudio.in

# Cloudinary (image uploads) — get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PRODUCT_FOLDER=svarnastudio/products
