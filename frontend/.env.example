# Copy to `.env` and adjust. Vite only exposes variables prefixed with VITE_.

# Backend (Express) origin, e.g. http://localhost:5500 — no trailing slash
VITE_API_BASE_URL=http://localhost:5500

# Contact form (https://web3forms.com)
VITE_WEB3FORMS_ACCESS_KEY=
VITE_WEB3FORMS_SUBMIT_URL=https://api.web3forms.com/submit
